# Keep build contexts small: only reader_app/ Python files + frontend are needed
# by the backend/frontend images; kokoro/ is needed only by the TTS image (kept
# via docker/Dockerfile.tts.dockerignore). Exclude deploy/docker artifacts, large
# model weights, audio, caches, and the legacy stack.
.git
.venv
venv
**/__pycache__
**/*.pyc
**/node_modules
*.wav
*.json.bak
kokoro/voices
kokoro/*.pth
legacy
reader_app/deploy
reader_app/docker
podcast_transcript.json
*.txt
!reader_app/requirements.txt
.DS_Store
**/.DS_Store
.claude
