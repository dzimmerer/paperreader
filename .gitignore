# ---- General ----
.DS_Store
Thumbs.db
*.swp
*.swo
*.orig

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
.env
.venv
venv/
env/

# Packaging / build
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/
.wheels/

# PyInstaller
*.spec

# Logs / profiling
*.log
profile.dat
.prof

# Coverage / test
.coverage
.coverage.*
htmlcov/
.cache/
.pytest_cache/
.tox/
.mypy_cache/
.dmypy.json
.pyre/
.pytype/

# Jupyter / IPython
.ipynb_checkpoints/

# Local data / artifacts
*.wav
*.mp3
*.flac
*.ogg
*.opus

# Model weights / large checkpoints.
# The large Kokoro model weight is NOT committed (download it separately);
# the small voice packs in kokoro/voices/*.pt (~0.5 MB each) ARE shipped.
kokoro/kokoro-v0_19.pth
kokoro/*.pth
!kokoro/voices/
*.ckpt
*.onnx

# Temporary text outputs / scratch dumps
podcast_transcript.json
spoken_text.txt
bib_text.txt
openai_output.wav
output.wav
/reqs.txt

# ---- Node / Frontend ----
# Covers both the legacy classic SPA (legacy/frontend) and any future frontends.
**/node_modules/
**/dist/
**/.vite/
*.tsbuildinfo

# npm / yarn / pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env files (if added later)
*.env
*.env.local
.env.development.local
.env.test.local
.env.production.local

# ---- Mac OS ----
.AppleDouble
.LSOverride
Icon?
__MACOSX/

# ---- Editor / IDE ----
.vscode/
.idea/
*.iml
.sourcemaps/
.claude/

# ---- Misc ----
# Backup files
*~
# Python byte-compiled in nested dirs
**/__pycache__/

# Prevent committing large raw HTML dumps if any
*.html.dump

# Generated audio chunk caches (if added later)
audio_cache/

# ---- Deployment-specific secrets / personal config ----
# TLS ingress manifest holds a personal email + domain; keep it local.
reader_app/deploy/k8s/tls-ingress.yaml
